	<string>Note0 needs microphone access to record and transcribe audio notes.</string>
	<key>NSAppleMusicUsageDescription</key>
	<string>Note0 needs access to your media library to play recorded notes.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Note0 uses the local network to communicate with the Dart debugger.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_dartobservatory._tcp</string>
	</array>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>https</string>
		<string>mailto</string>
		<string>itms-apps</string>
	</array>
